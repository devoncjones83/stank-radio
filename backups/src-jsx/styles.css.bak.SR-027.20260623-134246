    content: "";
    position: absolute;
    right: 17px;
    top: 50%;
    width: 8px;
    height: 8px;
    margin-top: -4px;
    border-radius: 50%;
    background: rgba(0,0,0,0.55);
    z-index: 3;
  }

  .industrialWarningStrip {
    position: relative;
  }

