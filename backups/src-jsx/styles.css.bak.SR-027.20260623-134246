:root {
  color: #f3edd7;
  background: #060604;
  font-family:
    Arial,
    Helvetica,
    sans-serif;
  --tar: #060604;
  --panel: rgba(10, 12, 8, 0.9);
  --panel-strong: rgba(4, 5, 3, 0.96);
  --paper: #f3edd7;
  --muted: #b5ad91;
  --acid: #a8ff32;
  --mold: #5e8f1c;
  --safety: #70a836;
  --blood: #f04a2f;
  --bruise: #406481;
  --line: rgba(243, 237, 215, 0.2);
  --green-line: rgba(168, 255, 50, 0.34);
  --shadow: 0 22px 80px rgba(0, 0, 0, 0.58);
}

* {
  box-sizing: border-box;
}

html,
body,
#root {
  min-height: 100%;
}

body {
  margin: 0;
  overflow-x: hidden;
  background: var(--tar);
}

button,
input {
  font: inherit;
}

button {
  cursor: pointer;
}

.radioApp {
  position: relative;
  min-height: 100vh;
  padding: clamp(0.75rem, 2vw, 1.4rem);
  isolation: isolate;
}

.backdrop,
.scanlines {
  position: fixed;
  inset: 0;
  pointer-events: none;
}

.backdrop {
  z-index: -3;
  background:
    linear-gradient(90deg, rgba(6, 6, 4, 0.95), rgba(6, 6, 4, 0.54) 48%, rgba(6, 6, 4, 0.86)),
    linear-gradient(0deg, rgba(6, 6, 4, 0.98), rgba(6, 6, 4, 0.16) 48%, rgba(6, 6, 4, 0.88)),
    var(--app-bg);
  background-size: cover;
  background-position: center;
}

.scanlines {
  z-index: 20;
  opacity: 0.22;
  mix-blend-mode: screen;
  background:
    repeating-linear-gradient(
      0deg,
      rgba(255, 255, 255, 0.12) 0 1px,
      transparent 1px 5px
    ),
    repeating-linear-gradient(
      90deg,
      rgba(168, 255, 50, 0.06) 0 1px,
      transparent 1px 17px
    );
}

.masthead,
.heroDeck,
.playerPanel,
.filterPanel,
.libraryPanel,
.warningPanel {
  border: 1px solid var(--line);
  background: var(--panel);
  box-shadow: var(--shadow);
  backdrop-filter: blur(12px) saturate(1.15);
}

.masthead {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  min-height: 4.25rem;
  padding: 0.75rem;
  border-color: var(--green-line);
}

.brand {
  min-width: 0;
  display: inline-flex;
  align-items: center;
  gap: 0.8rem;
  color: var(--paper);
  text-decoration: none;
}

.brand img {
  width: 3rem;
  height: 3rem;
  object-fit: cover;
  border: 1px solid var(--acid);
  filter: saturate(1.2) contrast(1.1);
}

.brand span {
  min-width: 0;
  display: grid;
  gap: 0.1rem;
}

.brand b,
h1,
h2,
.panelLabel,
.signalReadout b {
  font-family: Impact, Haettenschweiler, 'Arial Black', sans-serif;
  font-weight: 900;
  letter-spacing: 0;
  text-transform: uppercase;
}

.brand b {
  font-size: 2.25rem;
  line-height: 0.9;
  text-shadow: 0.06em 0.06em 0 var(--blood);
}

.brand small {
  color: var(--muted);
  font-size: 0.78rem;
  text-transform: uppercase;
}

.transmissionFlag {
  display: inline-flex;
  align-items: center;
  gap: 0.55rem;
  min-height: 2.5rem;
  padding: 0 0.8rem;
  border: 1px solid rgba(168, 255, 50, 0.52);
  background: rgba(10, 22, 5, 0.76);
  color: var(--acid);
  font-weight: 900;
  text-transform: uppercase;
  white-space: nowrap;
}

.transmissionFlag span {
  width: 0.75rem;
  height: 0.75rem;
  background: var(--acid);
  box-shadow: 0 0 18px var(--acid);
}

.headerRoomTone {
  display: grid;
  grid-template-columns: auto minmax(4.5rem, 1fr);
  grid-template-rows: auto auto;
  column-gap: 0.45rem;
  min-width: 9.25rem;
  padding: 0.38rem 0.55rem;
  border: 1px solid rgba(112, 168, 54, 0.52);
  background: rgba(6, 6, 4, 0.72);
}

.headerRoomTone > span {
  color: var(--safety);
  font-family: "Lucida Console", "Courier New", monospace;
  font-size: 0.6rem;
  font-weight: 900;
  text-transform: uppercase;
}

.headerRoomTone > b {
  overflow: hidden;
  color: var(--paper);
  font-size: 0.65rem;
  text-align: right;
  text-overflow: ellipsis;
  text-transform: uppercase;
  white-space: nowrap;
}

.headerRoomTone .meterBars {
  grid-column: 1 / -1;
  height: 1rem;
  margin-top: 0.22rem;
}

.headerSignal {
  display: grid;
  grid-template-columns: repeat(2, minmax(3.7rem, 1fr));
  gap: 0.3rem;
  min-width: 8.7rem;
}

.headerSignal div {
  display: grid;
  gap: 0.15rem;
  padding: 0.36rem 0.44rem;
  border: 1px solid rgba(112, 168, 54, 0.52);
  background: rgba(6, 6, 4, 0.72);
}

.headerSignal span {
  color: var(--muted);
  font-family: "Lucida Console", "Courier New", monospace;
  font-size: 0.54rem;
  font-weight: 900;
  line-height: 1.05;
  text-transform: uppercase;
}

.headerSignal b {
  color: var(--acid);
  font-family: Impact, Haettenschweiler, "Arial Black", sans-serif;
  font-size: 0.92rem;
  line-height: 0.95;
  text-transform: uppercase;
}

.manifestLink {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.35rem;
  min-height: 2.5rem;
  padding: 0 0.75rem;
  border: 1px solid rgba(112, 168, 54, 0.55);
  background: rgba(6, 6, 4, 0.7);
  color: var(--safety);
  font-size: 0.78rem;
  font-weight: 900;
  text-decoration: none;
  text-transform: uppercase;
  white-space: nowrap;
}

.manifestLink:hover,
.manifestLink:focus-visible {
  background: var(--safety);
  color: var(--tar);
  outline: none;
}

.playlistLink {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.35rem;
  min-height: 2.5rem;
  padding: 0 0.75rem;
  border: 1px solid rgba(168, 255, 50, 0.52);
  background: rgba(6, 6, 4, 0.7);
  color: var(--acid);
  font-size: 0.78rem;
  font-weight: 900;
  text-transform: uppercase;
  white-space: nowrap;
}

.playlistLink:hover,
.playlistLink:focus-visible {
  background: var(--acid);
  color: var(--tar);
  outline: none;
}

.heroDeck {
  position: relative;
  display: grid;
  grid-template-columns: minmax(0, 1.15fr) minmax(13.5rem, 0.85fr);
  gap: clamp(0.7rem, 2vw, 1.5rem);
  align-items: start;
  min-height: 15.5rem;
  margin: 0;
  padding: clamp(1rem, 3vw, 2rem);
  overflow: hidden;
  isolation: isolate;
  border-color: rgba(168, 255, 50, 0.58);
  background:
    linear-gradient(102deg, rgba(2, 5, 1, 0.97) 0 48%, rgba(13, 21, 5, 0.74) 70%, rgba(42, 15, 5, 0.72)),
    repeating-linear-gradient(91deg, rgba(168, 255, 50, 0.07) 0 1px, transparent 1px 8px),
    var(--track-cover);
  background-size: cover;
  background-position: center;
  box-shadow:
    inset 0 0 0 1px rgba(168, 255, 50, 0.1),
    inset 0 -2.25rem 3rem rgba(34, 48, 4, 0.4),
    var(--shadow);
}

.heroDeck::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    linear-gradient(0deg, rgba(3, 5, 1, 0.98), transparent 55%),
    repeating-linear-gradient(0deg, rgba(168, 255, 50, 0.06) 0 1px, transparent 1px 4px),
    repeating-linear-gradient(
      -11deg,
      rgba(240, 74, 47, 0.16) 0 2px,
      transparent 2px 15px
    );
  opacity: 0.82;
  mix-blend-mode: screen;
}

.heroDeck::after {
  content: "UNSANITIZED SIGNAL // 88.8";
  position: absolute;
  right: -2.75rem;
  bottom: 0.5rem;
  z-index: 0;
  padding: 0.24rem 0.55rem;
  color: rgba(168, 255, 50, 0.3);
  border: 1px solid rgba(168, 255, 50, 0.22);
  font-family: "Lucida Console", "Courier New", monospace;
  font-size: 0.5rem;
  font-weight: 900;
  letter-spacing: 0.09em;
  transform: rotate(-90deg);
}

.heroCopy,
.heroTelemetry {
  position: relative;
  z-index: 1;
}

.heroCopy {
  align-self: start;
}

.heroTagline {
  max-width: 32rem;
  margin: 0.55rem 0 0;
  color: rgba(246, 239, 212, 0.92);
  font-size: 0.8rem;
  font-weight: 800;
  line-height: 1.25;
  text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.86);
}

.heroTelemetry {
  display: grid;
  gap: 0.7rem;
  align-self: start;
  justify-self: end;
  width: min(13rem, 100%);
}

.eyebrow {
  margin: 0 0 0.55rem;
  color: var(--safety);
  font-size: 0.78rem;
  font-weight: 900;
  font-family: "Lucida Console", "Courier New", monospace;
  letter-spacing: 0;
  text-transform: uppercase;
}

h1 {
  max-width: none;
  margin: 0;
  color: var(--paper);
  font-size: 3.65rem;
  line-height: 0.8;
  overflow-wrap: anywhere;
  text-shadow:
    0.055em 0.045em 0 var(--blood),
    -0.025em 0.035em 0 var(--bruise);
}

.heroCopy h1 span {
  display: block;
  white-space: nowrap;
}

.heroCopy h1 {
  font-family: "Rockwell Extra Bold", Rockwell, "Arial Black", Georgia, serif;
  font-weight: 900;
  text-shadow:
    0.045em 0.05em 0 var(--blood),
    -0.02em 0.02em 0 var(--safety);
  -webkit-text-stroke: 1px rgba(6, 6, 4, 0.72);
  transform: rotate(-0.75deg);
}

.heroDescription {
  margin: 0;
  color: var(--paper);
  font-size: 0.78rem;
  line-height: 1.24;
}

.heroDescription strong {
  color: var(--acid);
  font-weight: 900;
}

.pipeBrief {
  position: relative;
  z-index: 1;
  display: grid;
  gap: 0.42rem;
  align-self: stretch;
  padding: 0.65rem 0.7rem 0.6rem 0.85rem;
  border: 1px solid rgba(168, 255, 50, 0.62);
  border-left: 4px solid var(--acid);
  background:
    linear-gradient(115deg, rgba(9, 17, 3, 0.96), rgba(27, 13, 4, 0.9)),
    repeating-linear-gradient(-24deg, rgba(168, 255, 50, 0.1) 0 1px, transparent 1px 7px);
  box-shadow: inset 0 0 1.1rem rgba(168, 255, 50, 0.1);
}

.pipeBriefLabel,
.riskNotice {
  margin: 0;
  font-family: "Lucida Console", "Courier New", monospace;
  font-size: 0.66rem;
  font-weight: 900;
  line-height: 1.15;
  text-transform: uppercase;
}

.pipeBriefLabel {
  color: var(--safety);
  text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.82);
}

.riskNotice {
  color: rgba(246, 239, 212, 0.72);
}

.heroFrequency {
  margin: 0;
  color: var(--acid);
  font-family: "Lucida Console", "Courier New", monospace;
  font-size: 0.72rem;
  font-weight: 900;
  line-height: 1.15;
  text-transform: uppercase;
  border-top: 1px solid rgba(168, 255, 50, 0.28);
  padding-top: 0.35rem;
}

.signalReadout {
  display: grid;
  gap: 0.35rem;
  padding: 0.65rem;
  border: 1px solid rgba(168, 255, 50, 0.45);
  background:
    linear-gradient(180deg, rgba(4, 5, 3, 0.92), rgba(4, 5, 3, 0.78)),
    repeating-linear-gradient(0deg, rgba(168, 255, 50, 0.12) 0 1px, transparent 1px 6px);
}

.signalBoxes {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.35rem;
}

.signalBox {
  display: grid;
  gap: 0.18rem;
  min-width: 0;
  padding: 0.42rem;
  border: 1px solid rgba(112, 168, 54, 0.48);
  background: rgba(0, 0, 0, 0.38);
}

.signalBox span {
  color: var(--muted);
  font-size: 0.6rem;
  line-height: 1.05;
}

.signalBox b {
  color: var(--acid);
  font-size: 1rem;
  line-height: 0.95;
}

.signalReadout span,
.signalReadout em,
.panelLabel,
.trackTag,
dt,
.lyricsHeading,
.playlistCard small {
  font-family: "Lucida Console", "Courier New", monospace;
}

.signalReadout span,
.signalReadout em {
  color: var(--muted);
  font-style: normal;
  font-weight: 800;
  text-transform: uppercase;
}

.signalReadout em {
  font-size: 0.56rem;
  line-height: 1.1;
}

.signalReadout b {
  color: var(--acid);
  font-size: 1rem;
  line-height: 0.9;
}

.roomTonePanel {
  padding: 0.6rem 0.65rem;
  border: 1px solid rgba(112, 168, 54, 0.48);
  background: rgba(5, 6, 4, 0.86);
}

.roomTonePanel .panelLabel {
  margin-bottom: 0.25rem;
  font-size: 0.72rem;
}

.roomToneReadout {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 0.75rem;
  margin-bottom: 0.3rem;
}

.roomToneReadout b {
  color: var(--paper);
  font-size: 0.78rem;
  text-transform: uppercase;
}

.roomToneReadout span {
  color: var(--acid);
  font-size: 0.64rem;
  font-weight: 900;
  text-transform: uppercase;
}

.workspaceGrid {
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.65fr);
  grid-template-areas:
    "hero filters"
    "player library"
    "warning library";
  gap: 0.75rem;
  margin-top: 0.75rem;
}

.consoleGrid {
  display: contents;
}

.heroDeck {
  grid-area: hero;
}

.playerPanel,
.filterPanel,
.libraryPanel,
.warningPanel {
  padding: clamp(0.85rem, 2vw, 1rem);
}

.playerPanel {
  grid-area: player;
  min-height: 0;
  display: flex;
  flex-direction: column;
  border-color: rgba(168, 255, 50, 0.34);
}

.filterPanel {
  grid-area: filters;
  align-self: start;
  padding: 0.65rem;
}

.filterHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.45rem;
  margin-bottom: 0.55rem;
}

.filterHeader .panelLabel {
  margin-bottom: 0;
  margin-right: auto;
}

.allTracksLink {
  color: var(--safety);
  border-color: rgba(112, 168, 54, 0.62);
}

.allTracksLink.active {
  background: rgba(112, 168, 54, 0.17);
  border-color: var(--safety);
}

.libraryPanel {
  grid-area: library;
  min-height: 0;
  align-self: stretch;
  background:
    linear-gradient(rgba(10, 12, 8, 0.92), rgba(10, 12, 8, 0.94)),
    url('/stank-radio/images/stank-radio-icon.png');
  background-size: auto, 5rem;
  background-position: center;
  background-repeat: repeat;
}

.warningPanel {
  grid-area: warning;
  padding: 0.65rem;
  border-color: rgba(240, 74, 47, 0.46);
  background:
    linear-gradient(90deg, rgba(42, 10, 7, 0.9), rgba(8, 7, 4, 0.88));
}

.warningPanel .panelLabel {
  margin-bottom: 0.45rem;
  font-size: 0.78rem;
}

.panelLabel {
  display: flex;
  align-items: center;
  gap: 0.45rem;
  margin-bottom: 0.85rem;
  color: var(--safety);
  font-size: 1rem;
}

.playerCore {
  display: grid;
  grid-template-columns: minmax(10rem, 15rem) minmax(0, 1fr);
  gap: clamp(1rem, 3vw, 1.6rem);
  align-items: stretch;
  flex: 0 0 auto;
}

.coverWell {
  position: relative;
  min-height: 13rem;
  border: 1px solid rgba(168, 255, 50, 0.36);
  background: var(--panel-strong);
  overflow: hidden;
}



.coverWell img {
  width: 100%;
  height: 100%;
  min-height: 13rem;
  object-fit: cover;
  filter: saturate(1.28) contrast(1.14);
}

.vinylBadge {
  position: absolute;
  left: 0.7rem;
  bottom: 0.7rem;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  padding: 0.28rem 0.38rem;
  background: var(--acid);
  color: var(--tar);
  font-size: 0.6rem;
  font-weight: 900;
  text-transform: uppercase;
}

.trackStack {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  min-width: 0;
}

.trackStack h2 {
  max-height: 2.75em;
  overflow: hidden;
  font-size: 2rem;
  line-height: 0.92;
}

.trackTag {
  width: fit-content;
  margin: 0 0 0.8rem;
  padding: 0.38rem 0.52rem;
  border: 1px solid rgba(112, 168, 54, 0.55);
  color: var(--safety);
  font-size: 0.78rem;
  font-weight: 900;
  text-transform: uppercase;
}

h2 {
  margin: 0;
  color: var(--paper);
  font-size: 2.85rem;
  line-height: 0.9;
  overflow-wrap: anywhere;
  text-shadow: 0.04em 0.045em 0 rgba(240, 74, 47, 0.9);
}

.trackStack > p:not(.trackTag) {
  max-width: 44rem;
  margin: 1rem 0 0;
  color: var(--muted);
  font-size: 1.05rem;
  line-height: 1.48;
  max-height: 2.96em;
  overflow: hidden;
}

.trackMeta {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.6rem;
  margin: auto 0 0;
  padding: 0;
}

.trackMeta div {
  min-width: 0;
  padding-top: 0.8rem;
  border-top: 1px solid var(--line);
}

dt {
  color: var(--safety);
  font-size: 0.72rem;
  font-weight: 900;
  text-transform: uppercase;
}

dd {
  margin: 0.25rem 0 0;
  overflow: hidden;
  color: var(--paper);
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.transportBar {
  display: grid;
  grid-template-columns: 3rem minmax(9rem, 13rem) 3rem repeat(2, minmax(6rem, 1fr));
  gap: 0.45rem;
  margin-top: auto;
  padding-top: 0.75rem;
  flex: 0 0 auto;
}

.playerPanel > audio {
  display: none;
}

.transportBar button,
.trackRow {
  border: 1px solid var(--line);
  background: rgba(6, 6, 4, 0.72);
  color: var(--paper);
}

.transportBar button {
  min-height: 3rem;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.4rem;
  font-weight: 900;
  text-transform: uppercase;
}

.transportBar button:hover,
.transportBar button:focus-visible,
.trackRow:hover,
.trackRow:focus-visible {
  outline: none;
  border-color: var(--acid);
  box-shadow: 0 0 0 1px rgba(168, 255, 50, 0.24);
}

.transportBar .primaryPlay {
  background: var(--blood);
  border-color: var(--blood);
  color: var(--paper);
}

.transportBar .primaryPlay:disabled {
  cursor: not-allowed;
  opacity: 0.46;
}

.sourceLine {
  min-height: 2.2rem;
  display: flex;
  align-items: center;
  margin-top: 0.7rem;
  color: var(--muted);
  font-size: 0.84rem;
  font-weight: 800;
}

.sourceLine a {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  color: var(--acid);
  text-decoration: none;
}

.sourceLine a:hover,
.sourceLine a:focus-visible {
  color: var(--safety);
  outline: none;
}

.lyricsPanel {
  margin-top: 0.9rem;
  padding-top: 0.85rem;
  border-top: 1px solid var(--line);
}

.lyricsHeading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  margin-bottom: 0.55rem;
  color: var(--safety);
  font-size: 0.76rem;
  font-weight: 900;
  text-transform: uppercase;
}

.lyricsHeading b {
  color: var(--muted);
  font-size: 0.72rem;
}

.lyricsScroll {
  max-height: 12rem;
  overflow: auto;
  padding: 0.25rem 0.6rem 0.25rem 0;
}

.lyricsScroll p {
  margin: 0;
  padding: 0.5rem 0;
  color: rgba(181, 173, 145, 0.72);
  font-size: 1rem;
  line-height: 1.35;
  transition: color 160ms ease, padding-left 160ms ease;
}

.lyricsScroll p.active {
  padding-left: 0.65rem;
  border-left: 0.25rem solid var(--acid);
  color: var(--paper);
  font-weight: 900;
}

.lyricsScroll .lyricsEmpty {
  color: var(--muted);
  font-size: 0.9rem;
}

.playlistModal {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: grid;
  place-items: center;
  padding: 1rem;
  background: rgba(0, 0, 0, 0.76);
  backdrop-filter: blur(8px);
}

.playlistModalPanel {
  width: min(60rem, 100%);
  max-height: min(44rem, calc(100vh - 2rem));
  overflow: auto;
  padding: 1rem;
  border: 1px solid rgba(168, 255, 50, 0.58);
  background: #0a0c08;
  box-shadow: 0 24px 90px rgba(0, 0, 0, 0.7);
}

.playlistModalHead {
  display: flex;
  align-items: start;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1rem;
  border-bottom: 1px solid var(--line);
  padding-bottom: 1rem;
}

.playlistModalHead h2 {
  font-size: 2.5rem;
}

