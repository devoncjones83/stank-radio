* {
  box-sizing: border-box;
}

html,
body,
#root {
  width: 100%;
  height: 100%;
  margin: 0;
  overflow: hidden;
}

body {
  background:
    url("/images/branding/stank-radio-bg.png")
    center center / cover
    no-repeat fixed;
  font-family: Arial, Helvetica, sans-serif;
}

.radioApp {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: transparent;
}

.industrialShell {
  width: 100vw;
  height: 100vh;
  display: grid;
  grid-template-columns: 1380fr 520fr;
  grid-template-rows: 150px minmax(0, 1fr) 110px;
  grid-template-areas:
    "header header"
    "player library"
    "footer footer";
  gap: 0;
  padding: 0;
  margin: 0;
  overflow: hidden;
  background: transparent;
}

.industrialHeader {
  grid-area: header;
  background:
    url("/images/industrial-header-filthup-v1.png")
    center center / 100% 100%
    no-repeat;
}

.industrialPlayerShell {
  grid-area: player;
  background:
    url("/images/industrial-player-shell-v2-final.png")
    center center / contain
    no-repeat;
}

.industrialLibraryBay {
  grid-area: library;
  background:
    url("/images/industrial-library-frame-v1.png")
    center center / contain
    no-repeat;
}

.industrialWarningStrip {
  grid-area: footer;
  background:
    url("/images/industrial-warning-banner-v1.png")
    center center / 100% 100%
    no-repeat;
}
