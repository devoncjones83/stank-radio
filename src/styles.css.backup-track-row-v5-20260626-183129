@import url('https://fonts.googleapis.com/css2?family=VT323&display=swap');

/* === BASE === */
:root {
  color: #f3edd7;
  background: #060604;
  font-family: Arial, Helvetica, sans-serif;
  --acid: #a8ff32;
  --muted: #b5ad91;
  --paper: #f3edd7;
  --blood: #f04a2f;
  --green-line: rgba(168, 255, 50, 0.34);
}

* { box-sizing: border-box; }

html, body, #root {
  width: 100%;
  height: 100%;
  margin: 0;
  overflow: hidden;
}

body {
  background-color: #111009;
  background-image:
    radial-gradient(ellipse at 15% 25%, rgba(80, 45, 12, 0.4) 0%, transparent 55%),
    radial-gradient(ellipse at 85% 75%, rgba(60, 35, 8, 0.45) 0%, transparent 55%),
    radial-gradient(ellipse at 50% 50%, rgba(25, 15, 4, 0.5) 0%, transparent 80%),
    repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,0,0,0.06) 3px, rgba(0,0,0,0.06) 4px),
    repeating-linear-gradient(90deg, transparent, transparent 3px, rgba(0,0,0,0.04) 3px, rgba(0,0,0,0.04) 4px),
    linear-gradient(135deg, #1c1308 0%, #0e0b04 40%, #141008 70%, #0a0804 100%);
  font-family: Arial, Helvetica, sans-serif;
}

button, input { font: inherit; }
audio { display: none; }

/* === SHELL WRAPPER === */

.radioApp {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: transparent;
}

.industrialShell {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  position: relative;
  background: transparent;
}

/* === HEADER (150px tall, full width) === */

.industrialHeader {
  position: fixed;
  top: 0; left: 0;
  width: 100vw;
  height: 150px;
  z-index: 30;
  overflow: hidden;
  background: url("/images/industrial-header-filthup-v1.png") center center / 100% 100% no-repeat;
}

/* Hide static copy panels — header image already shows this info */
.broadcastIdentityPanel,
.broadcastDefinitionPanel,
.broadcastContaminantsPanel {
  display: none;
}

/* Dynamic status area: live badge, stank load, view toggle */
.broadcastStatusPanel {
  position: absolute;
  top: 0; right: 0;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
  gap: 0.4rem;
  padding: 0.5rem 1rem;
  z-index: 5;
}

.liveContainmentBadge {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.7rem;
  font-weight: 900;
  color: #b7ff2b;
  letter-spacing: 0.08em;
}

.liveContainmentBadge span {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: #b7ff2b;
  display: inline-block;
}

.broadcastIndexedBox {
  font-size: 0.65rem;
  color: #b7ff2b;
  text-align: right;
  line-height: 1.2;
}

.broadcastIndexedBox span { display: block; opacity: 0.7; }
.broadcastIndexedBox b { font-size: 0.9rem; }

.broadcastWaveform {
  display: flex;
  align-items: flex-end;
  gap: 2px;
  height: 24px;
}

.broadcastWaveform i {
  display: block;
  width: 3px;
  background: #a8ff32;
  height: var(--meter-height, 30%);
  opacity: 0.7;
}

.broadcastStatusControls {
  display: flex;
  align-items: center;
  gap: 0.6rem;
}

.viewToggle {
  border: 1px solid rgba(190, 255, 65, 0.6);
  background: rgba(5, 12, 3, 0.85);
  color: #caff3a;
  font-size: 0.7rem;
  font-weight: 900;
  letter-spacing: 0.06em;
  cursor: pointer;
  padding: 0.3rem 0.7rem;
}

.viewToggle:hover {
  background: rgba(168, 255, 50, 0.15);
}

/* === PLAYER SHELL (left panel) === */

.industrialPlayerShell {
  position: fixed;
  left: 0;
  top: 142px;
  right: calc(700px + 1%);
  height: calc(100vh - 142px - 82px);
  z-index: 10;
  background: url("/images/industrial-player-shell-v2-final.png") center center / 100% 100% no-repeat;
}

/* Frame image is on top of content via ::after */
.industrialPlayerShell::after {
  content: "";
  position: absolute;
  inset: 0;
  background: url("/images/industrial-player-shell-v2-final.png") center center / 100% 100% no-repeat;
  pointer-events: none;
  z-index: 50;
}

/* Remove the background from the shell itself so content shows through */
.industrialPlayerShell {
  background: none;
}

/* === PLAYER SHELL CONTENT === */
/* Percentages match cutout positions in the frame image */

.shellCoverViewport,
.shellVizViewport,
.shellDossierPanel,
.shellLyricsPanel,
.industrialTransport,
.shellTitleStrip {
  position: absolute;
}

.shellTitleStrip {
  display: none;
}

/* Fumes gauge — positioned over the meter dial in the shell image */
.shellMeters {
  position: absolute;
  left: 3%;
  top: 55%;
  width: 25%;
  height: 20%;
  z-index: 20;
  pointer-events: none;
}

.shellNeedleIndex { display: none; }

/* Fumes needle pivot centered at bottom of meter area */
.shellNeedleFumes {
  display: block;
  position: absolute;
  bottom: 10%;
  left: 50%;
  width: 3px;
  height: 44%;
  background: linear-gradient(to top, #caff3a, rgba(202, 255, 58, 0.5));
  transform-origin: bottom center;
  transform: translateX(-50%) rotate(var(--needle-angle, -70deg));
  transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  border-radius: 2px 2px 0 0;
  box-shadow: 0 0 4px rgba(202, 255, 58, 0.6);
}

/* Pivot pin */
.shellNeedleFumes::after {
  content: "";
  position: absolute;
  bottom: -4px;
  left: 50%;
  transform: translateX(-50%);
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #caff3a;
  box-shadow: 0 0 6px rgba(202, 255, 58, 0.8);
}

.shellCoverViewport {
  left: 26%;
  top: 4%;
  width: 43%;
  height: 74%;
  overflow: hidden;
  z-index: 10;
}

.shellCoverViewport img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.shellCoverViewport em {
  position: absolute;
  top: 0.75rem; left: 0.75rem;
  background: #b7ff2b;
  color: #061000;
  padding: 0.3rem 0.55rem;
  font-size: 0.7rem;
  font-weight: 900;
  font-style: normal;
}

.shellVizViewport {
  left: 73%;
  top: 8%;
  width: 24%;
  height: 19%;
  background: rgba(0, 8, 0, 0.2);
  overflow: hidden;
  z-index: 20;
}

.shellScopeTrace {
  width: 100%;
  height: 100%;
  background:
    repeating-linear-gradient(0deg, rgba(167, 255, 50, .1) 0 1px, transparent 1px 8px),
    linear-gradient(90deg, transparent 0 10%, rgba(174, 255, 45, .65) 50%, transparent 90%);
  animation: scopePulse 1.4s linear infinite;
}

@keyframes scopePulse {
  from { transform: translateX(-20%); }
  to   { transform: translateX(20%); }
}

.shellDossierPanel,
.shellLyricsPanel {
  left: 73%;
  width: 24%;
  padding: 0.6rem 0.8rem;
  color: #f4f0d6;
  background: rgba(0, 0, 0, 0.7);
  overflow: hidden;
  text-shadow: 1px 1px 0 #000;
  z-index: 20;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.shellDossierPanel { top: 29%; height: 23%; }
.shellLyricsPanel  { top: 55%; height: 24%; }

.terminalPlate {
  font-size: 0.62rem;
  font-weight: 900;
  color: #b7ff2b;
  letter-spacing: 0.1em;
  margin-bottom: 0.3rem;
}

.shellDossierPanel h2 {
  margin: 0.25rem 0;
  color: #b7ff2b;
  font-size: 0.9rem;
  line-height: 1.1;
}

.shellDossierPanel p,
.shellLyricsPanel p,
.shellLyricsPanel span {
  margin: 0.2rem 0;
  font-size: 0.68rem;
  line-height: 1.25;
}

.lyricsScroll {
  height: calc(100% - 1.4rem);
  overflow-y: auto;
  scrollbar-width: none;
}

.lyricsScroll p {
  color: #b5ad91;
  transition: color 0.2s;
}

.lyricsScroll p.active {
  color: #b7ff2b;
  font-weight: 700;
}

.industrialLyricsEmpty {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.industrialLyricsEmpty b {
  color: #b7ff2b;
  font-size: 0.66rem;
}

.industrialTransport {
  left: 52%;
  bottom: 1%;
  width: 34%;
  height: 22%;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-evenly;
  gap: 0;
  z-index: 60;
}

.industrialTransport button {
  width: 11%;
  aspect-ratio: 1;
}

.industrialTransport button {
  border: none;
  background: rgba(5, 12, 3, 0.75);
  color: #caff3a;
  font-size: 0.7rem;
  font-weight: 900;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.2rem;
}

.industrialTransport button:hover {
  background: rgba(168, 255, 50, 0.12);
}

.industrialTransport button:first-child {
  position: relative;
  left: 2%;
}

.industrialTransport button:nth-child(4) {
  position: relative;
  left: -2%;
}

.industrialTransport button:nth-child(2) {
  position: relative;
  left: 1%;
}

.industrialTransport button:nth-child(5) {
  position: relative;
  left: -3.5%;
}

.industrialTransport button:disabled {
  opacity: 0.35;
  cursor: default;
}

.industrialStartLeak {
  font-size: 0.8rem !important;
  color: #caff3a !important;
  opacity: 1 !important;
  filter: brightness(1.4);
}

/* === LIBRARY BAY (right panel, 450px wide) === */

.industrialLibraryBay {
  position: fixed;
  right: 0;
  top: 150px;
  width: calc(700px + 2%);
  height: calc(100vh - 150px - 110px);
  z-index: 15;
  background: none;
}

.industrialLibraryBay::before {
  content: "";
  position: absolute;
  inset: 0;
  background: url("/images/industrial-library-bg-v1.png") center center / 100% 100% no-repeat;
  pointer-events: none;
  z-index: 0;
}

.industrialLibraryBay::after {
  content: "";
  position: absolute;
  inset: 0;
  background: url("/images/industrial-library-frame-v1.png") center center / 100% 100% no-repeat;
  pointer-events: none;
  z-index: 50;
}

/* All library content absolutely positioned within bay */

.libraryButtons {
  position: absolute;
  top: 2.5%;
  left: 55%;
  right: 2%;
  height: 10%;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 0.4rem;
  z-index: 5;
}

.libraryButtons .playlistLink {
  padding: 0.35rem 0.7rem;
  font-size: 0.78rem;
  height: 100%;
}

.panelLabel {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.7rem;
  font-weight: 900;
  color: #b7ff2b;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  flex-shrink: 0;
}

.playlistLink {
  border: 1px solid rgba(190, 255, 65, .45);
  background: rgba(5, 12, 3, 0.72);
  color: #caff3a;
  font-size: 0.68rem;
  font-weight: 900;
  cursor: pointer;
  padding: 0.25rem 0.45rem;
  display: flex;
  align-items: center;
  gap: 0.2rem;
  white-space: nowrap;
}

.playlistLink.active {
  background: rgba(168, 255, 50, 0.18);
  border-color: rgba(190, 255, 65, .8);
}

.searchBox {
  position: absolute;
  top: 5%;
  left: 6%;
  width: 56%;
  height: 5%;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.04);
  padding: 0 0.4rem;
  z-index: 5;
}

.searchBox input {
  width: 100%;
  border: 0;
  outline: 0;
  color: #caff3a;
  background: transparent;
  font-weight: 700;
  font-size: 0.82rem;
  caret-color: #caff3a;
}

.searchBox input::placeholder {
  color: rgba(202, 255, 58, 0.45);
}

.searchBox {
  border-bottom: 1px solid rgba(202, 255, 58, 0.3);
}

.trackList {
  position: absolute;
  left: 3%;
  right: 2%;
  top: 30%;
  bottom: 15%;
  display: grid;
  grid-template-rows: repeat(5, minmax(0, 1fr));
  gap: 0.25rem;
  z-index: 5;
}

.emptyLibrary {
  font-size: 0.75rem;
  color: #b5ad91;
  padding: 1rem 0;
}

.trackRow {
  position: relative;
  display: grid;
  grid-template-columns: 92px minmax(0, 1fr);
  align-items: center;
  gap: 0.85rem;
  padding: 0.3rem 0.6rem 0.3rem 0.35rem;
  border: none;
  /* Layer 1: track row background metal texture */
  background: url("/images/industrial-track-row-bg.png") center center / 100% 100% no-repeat;
  color: #f4f0d6;
  text-align: left;
  cursor: pointer;
  overflow: hidden;
}

/* Layer 3: track row frame (on top, corners cover the cover-art edges) */
.trackRow::after {
  content: "";
  position: absolute;
  inset: 0;
  background: url("/images/industrial-track-row-v5-off.png") center center / 100% 100% no-repeat;
  pointer-events: none;
  z-index: 2;
}

.trackRow.active {
  background:
        url("/images/industrial-track-row-v5-on.png")
        center center / 100% 100%
        no-repeat;
}

/* Layer 2: cover art + text, between bg and frame */
.trackRow img {
  position: relative;
  z-index: 1;
  width: 92px;
  height: 66px;
  object-fit: cover;
  display: block;
}

.trackRow .trackRowText {
  position: relative;
  z-index: 1;
}

.trackRow b,
.trackRow small {
  display: block;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.trackRow b { font-size: 1.1rem; }
.trackRow small { font-size: 0.82rem; opacity: 0.85; }

.libraryPagination {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 2%;
  height: 8%;
  z-index: 5;
}

/* Transparent click targets overlaying the green arrow graphics */
.libraryPagination button {
  position: absolute;
  top: 0;
  width: 13%;
  height: 100%;
  border: none;
  /* TEMP DEBUG: translucent red so button hit-area is visible */
  background: rgba(255, 0, 0, 0.4);
  color: #caff3a;
  font-size: 1.4rem;
  font-weight: 900;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s;
}

.libraryPagination button:first-child { left: 18%; }
.libraryPagination button:last-child  { left: 69%; }

.libraryPagination button:hover:not(:disabled) {
  background: rgba(168, 255, 50, 0.12);
}

.libraryPagination button:disabled {
  opacity: 0;
  cursor: default;
  pointer-events: none;
}

/* Page indicator centered between the two buttons */
.libraryPagination span {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  color: #caff3a;
  font-family: 'VT323', monospace;
  font-size: 1.3rem;
  letter-spacing: 0.05em;
  text-shadow: 0 0 6px rgba(202, 255, 58, 0.7);
  white-space: nowrap;
}

/* === WARNING STRIP (bottom) === */
/* Image is 1536x1024. Content band is ~30–46% from top.
   We display the image at 560px tall and crop to show just the band. */

.industrialWarningStrip {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  width: 100vw;
  height: 110px;
  z-index: 60;
  pointer-events: none;
  background: url("/images/industrial-warning-banner-v1.png") center 47% / 101% 560px no-repeat;
}

.warningPlate {
  display: none; /* baked into the image */
}

/* === CONTAINMENT VIEW — header signal panel === */

.headerSignal {
  display: flex;
  gap: 1.2rem;
  align-items: center;
  padding: 0 1rem;
}

.headerSignal > div {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.1rem;
  border: 1px solid rgba(190, 255, 65, 0.3);
  background: rgba(5, 12, 3, 0.75);
  padding: 0.3rem 0.7rem;
  min-width: 80px;
  text-align: center;
}

.headerSignal span {
  font-size: 0.6rem;
  font-weight: 900;
  color: #b5ad91;
  letter-spacing: 0.07em;
  text-transform: uppercase;
}

.headerSignal b {
  font-size: 1.1rem;
  color: #caff3a;
  line-height: 1;
}

/* Digital grainy track count display */
.digitalCount {
  font-family: 'VT323', monospace;
  font-size: 2.4rem;
  line-height: 1;
  color: #caff3a;
  letter-spacing: 0.05em;
  text-shadow:
    0 0 6px rgba(202, 255, 58, 0.9),
    0 0 14px rgba(202, 255, 58, 0.5),
    1px 1px 0 rgba(0, 0, 0, 0.8);
  filter: contrast(1.1);
}

/* === MODALS === */

.playlistModal,
.playerModal {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.78);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.playerModalPanel {
  background: rgba(8, 12, 5, 0.97);
  border: 1px solid rgba(168, 255, 50, 0.3);
  padding: 2rem;
  max-width: 90vw;
  max-height: 85vh;
  overflow-y: auto;
  scrollbar-width: thin;
}

/* === INDUSTRIAL PLAYLIST MODAL === */
.playlistModalPanel {
  width: min(1100px, 92vw);
  max-height: 88vh;
  overflow-y: auto;
  scrollbar-width: thin;
  padding: 1.75rem 2rem 2rem;
  color: #f4f0d6;
  background:
    repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,0,0,0.18) 3px, rgba(0,0,0,0.18) 4px),
    linear-gradient(135deg, #1c1308 0%, #0e0b04 45%, #14100a 75%, #0a0804 100%);
  border: 2px solid rgba(168, 255, 50, 0.45);
  border-radius: 6px;
  box-shadow:
    0 0 0 1px rgba(0,0,0,0.6),
    0 0 40px rgba(168, 255, 50, 0.12),
    inset 0 0 60px rgba(0,0,0,0.55);
}

.playlistModalHead {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 1.5rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid rgba(168, 255, 50, 0.25);
}

.playlistModalHead h2 {
  color: #b7ff2b;
  margin: 0.25rem 0 0;
  font-size: 1.8rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  text-shadow: 0 0 12px rgba(168, 255, 50, 0.4);
}

.eyebrow {
  font-size: 0.72rem;
  color: #b5ad91;
  letter-spacing: 0.06em;
  margin: 0;
}

.modalDismiss {
  border: 1px solid rgba(190, 255, 65, .4);
  background: rgba(5, 12, 3, 0.8);
  color: #caff3a;
  font-weight: 900;
  cursor: pointer;
  padding: 0.4rem 0.9rem;
}

.playlistGrid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1rem;
}

.playlistCard {
  display: flex;
  gap: 1rem;
  align-items: center;
  border: 1px solid rgba(168, 255, 50, 0.25);
  background:
    linear-gradient(135deg, rgba(20, 28, 10, 0.9), rgba(8, 12, 5, 0.92));
  color: #f4f0d6;
  cursor: pointer;
  text-align: left;
  padding: 0.85rem;
  border-radius: 4px;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.05), 0 4px 12px rgba(0,0,0,0.4);
  transition: transform 0.12s, border-color 0.12s, box-shadow 0.12s;
}

.playlistCard:hover {
  background: linear-gradient(135deg, rgba(30, 42, 14, 0.95), rgba(12, 18, 6, 0.95));
  border-color: rgba(168, 255, 50, 0.7);
  transform: translateY(-2px);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.08), 0 8px 22px rgba(0,0,0,0.5), 0 0 18px rgba(168,255,50,0.15);
}

.playlistArt {
  width: 84px;
  height: 84px;
  flex-shrink: 0;
  overflow: hidden;
  border: 1px solid rgba(168, 255, 50, 0.35);
  border-radius: 3px;
  background: rgba(168, 255, 50, 0.06);
  box-shadow: inset 0 0 18px rgba(0,0,0,0.6);
}

.playlistArt img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.playlistCardCopy {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  min-width: 0;
}

.playlistCardCopy b {
  font-size: 1.05rem;
  color: #b7ff2b;
  letter-spacing: 0.03em;
  text-transform: uppercase;
}
.playlistCardCopy small {
  font-size: 0.72rem;
  color: #caff3a;
  font-weight: 700;
  letter-spacing: 0.05em;
}
.playlistCardCopy em { font-size: 0.74rem; font-style: normal; color: #b5ad91; line-height: 1.3; }

.playlistModal .modalDismiss {
  font-size: 0.85rem;
  padding: 0.5rem 1.1rem;
  border-radius: 4px;
}

.playerModalPanel {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  min-width: 320px;
}

.playerModalCover {
  width: 100%;
  max-height: 240px;
  object-fit: cover;
}

.playerModalCopy p { margin: 0; font-size: 0.72rem; color: #b5ad91; }
.playerModalCopy h2 { margin: 0.25rem 0; color: #b7ff2b; }
.playerModalCopy span { font-size: 0.78rem; color: #f4f0d6; }

.playerModalAudio {
  display: block !important;
  width: 100%;
}
